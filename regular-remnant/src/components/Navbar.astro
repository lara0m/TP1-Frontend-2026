---
import Layout from "../layouts/Layout.astro";
---

    <nav class="navbar">
    <span class="navbar-logo">F1 <span class="accent">2026</span></span>  
    <ul class="navbar-links">
        <li><a href="/">Inicio</a></li>
        <li><a href="/pilotos">Pilotos</a></li>
        <li><a href="/carreras">Calendario 2026</a></li>
    </ul>
    </nav>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 40px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .navbar-logo {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }
  .accent { color: var(--accent); }
  .navbar-links {
    display: flex;
    gap: 24px;
    list-style: none;
  }
  .navbar-links a {
    color: var(--text-secondary);
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .navbar-links a:hover { color: var(--text-primary); }
  h1.meetings-container {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>