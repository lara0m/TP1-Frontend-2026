<!doctype html>


<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{"F1 2026"}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <!-- SPLASH SCREEN -->
<div id="splash">
  <div class="splash-content">
    <div class="splash-f1">
      <span class="splash-f">F</span>
      <span class="splash-one">1</span>
    </div>
    <div class="splash-line"></div>
    <p class="splash-sub">TEMPORADA 2026</p>
  </div>
</div>

<script>
  window.addEventListener('load', () => {
    const splash = document.getElementById('splash');
    setTimeout(() => {
      splash?.classList.add('hidden');
    }, 2000);
  });
</script>

<style>
  #splash {
    position: fixed;
    inset: 0;
    background: #0f0f0f;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }
  #splash.hidden {
    opacity: 0;
    visibility: hidden;
  }

  .splash-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    animation: splashIn 0.6s ease forwards;
  }

  .splash-f1 {
    font-size: 8rem;
    font-weight: 900;
    letter-spacing: -8px;
    line-height: 1;
  }
  .splash-f {
    color: #ffffff;
  }
  .splash-one {
    color: #e8002d;
  }

  .splash-line {
    width: 0;
    height: 3px;
    background: #e8002d;
    animation: expandLine 0.8s ease 0.4s forwards;
  }

  .splash-sub {
    font-size: 0.85rem;
    letter-spacing: 6px;
    color: #a0a0a0;
    opacity: 0;
    animation: fadeInSub 0.5s ease 0.9s forwards;
  }

  @keyframes splashIn {
    from { opacity: 0; transform: scale(0.8); }
    to   { opacity: 1; transform: scale(1); }
  }

  @keyframes expandLine {
    from { width: 0; }
    to   { width: 180px; }
  }

  @keyframes fadeInSub {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>	
  <body>
    <slot />
  </body>
</html>
<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
