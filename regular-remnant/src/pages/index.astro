---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
---

<Layout>
  <Navbar />
  <Hero />
  <div class="landing-content">
    <p>Bienvenido al portal no oficial de la Fórmula 1 para la temporada 2026.</p>
    <p>Explora los equipos, pilotos y conoce las pistas donde se correrá el próximo campeonato.</p>
  </div>
</Layout>

<style>
  .landing-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    color: var(--text-secondary);
    line-height: 1.6;
    padding: 20px;
  }
</style>
